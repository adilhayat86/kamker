# Required for real production signup, browsing, admin review, uploads, and matching.
# Local development can still use the ignored .kamker-local fallback for worker signup
# when these are missing. Production never uses that fallback.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Public marketplace media: worker photos, company staff photos, logos, gallery images/videos.
# Payment/proof images stay in Supabase Storage.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional local-only switch. Set to disabled to force missing-Supabase errors in dev.
KAMKER_LOCAL_DEMO_STORE=enabled

OPENAI_API_KEY=
AI_REVIEW_MODEL=gpt-4o-mini
AI_REVIEW_AUTO_APPROVE_CONFIDENCE=0.85

# Admin auth. KAMKER_ADMIN_PASSWORD remains a legacy owner fallback.
KAMKER_ADMIN_PASSWORD=
KAMKER_OWNER_ADMIN_PASSWORD=
KAMKER_MANAGER_ADMIN_PASSWORD=
KAMKER_AUTH_SECRET=
NEXT_PUBLIC_SITE_URL=

# Optional email provider for admin password reset links.
RESEND_API_KEY=
KAMKER_EMAIL_FROM=

NEXT_PUBLIC_KAMKER_SUPPORT_WHATSAPP=
NEXT_PUBLIC_PAYMENT_ACCOUNT_TITLE=adil hayat
NEXT_PUBLIC_PAYMENT_ACCOUNT_NUMBER=03005314191
NEXT_PUBLIC_PAYMENT_BANK_NAME=EasyPaisa
NEXT_PUBLIC_PAYMENT_WHATSAPP_NUMBER=923005314191

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_ADMIN_ALERT_TEMPLATE_NAME=kamker_admin_alerts
WHATSAPP_ADMIN_ALERT_TEMPLATE_LANGUAGE=en
WHATSAPP_REQUIREMENT_TEMPLATE_NAME=kamker_requirement_broadcast
WHATSAPP_REQUIREMENT_TEMPLATE_LANGUAGE=en
KAMKER_ADMIN_WHATSAPP=
